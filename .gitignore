.env
agent/.env
frontend/node_modules/
frontend/dist/
__pycache__/
*.pyc
.pytest_cache/
.claude/

# AWS SAM build artifacts (generated by `sam build` — thousands of copied deps)
infra/.aws-sam/
.aws-sam/
samconfig.toml

# Raw content-engine source material may contain real client PII
# (session transcripts, Niki's method sheets, work-item lists, the fillable
# worksheet PDFs). Keep those LOCAL — never commit them. But the anonymized,
# de-identified model notes (*.source.md / *.template.md) and READMEs ARE the
# deterministic model and SHOULD be tracked.
content-sources/01-transcripts/*
content-sources/02-niki-method-excel/*
content-sources/03-andrea-work-items/*
# In 04-domain-notes, ignore raw uploads (xlsx/pdf/docx/csv) but keep .md notes.
content-sources/04-domain-notes/*.xlsx
content-sources/04-domain-notes/*.xls
content-sources/04-domain-notes/*.csv
content-sources/04-domain-notes/*.pdf
content-sources/04-domain-notes/*.docx
# Always keep the scaffolding/README even in the ignored raw folders.
!content-sources/**/README.md
!content-sources/**/*.template.md
!content-sources/**/*.source.md

# Real client IP + PII: session transcripts and Niki's proprietary method sheets.
# NEVER commit — real people's names and end-of-life details are in here.
docs/decode_finalplaybook_niki's_ip/
