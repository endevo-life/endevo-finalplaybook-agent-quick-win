# Copy this file to .env and fill in real values. Never commit .env itself.

# =========================================================================
# LLM (paid tier only -- the free/rules tier needs none of this)
# =========================================================================
# "anthropic" -- direct Claude API, needs ANTHROPIC_API_KEY. Best grounding.
# "bedrock"   -- open-weight model via AWS Bedrock. Auth is your AWS credentials
#                (~/.aws/credentials) -- NO API key. Weaker grounding; see
#                docs/guardrails.md before using for real users.
LLM_BACKEND=anthropic

# --- Only when LLM_BACKEND=anthropic ---
ANTHROPIC_API_KEY=

# --- Only when LLM_BACKEND=bedrock (uses your AWS creds, no key needed) ---
# BEDROCK_MODEL_ID must be an INFERENCE-PROFILE id (note the "us." prefix); the
# bare "meta.llama3-..." id fails on-demand. List yours with:
#   aws bedrock list-inference-profiles --region us-east-1
# Cheap/minimal picks: us.meta.llama3-2-1b-instruct-v1:0 (1B),
#   us.meta.llama3-2-3b-instruct-v1:0 (3B), us.meta.llama3-1-8b-instruct-v1:0 (8B).
# Stronger: us.meta.llama4-scout-17b-instruct-v1:0, us.meta.llama3-3-70b-instruct-v1:0.
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=us.meta.llama3-1-8b-instruct-v1:0

# =========================================================================
# Persistence (users, entitlements, sessions, usage metering)
# =========================================================================
# "memory"   -- in-process, LOST ON RESTART (tests only).
# "sqlite"   -- local file, persists, zero setup (offline local dev).
# "dynamodb" -- AWS. Uses 5 tables: {prefix}users, sessions, usage, plans, chat.
STORE_BACKEND=dynamodb
SQLITE_PATH=final_playbook.db     # only used when STORE_BACKEND=sqlite
# Prefix for the DynamoDB tables (env-scoped, sits alongside your other tables).
# Creates: mfp-dev-users, mfp-dev-sessions, mfp-dev-usage, mfp-dev-plans, mfp-dev-chat
DDB_TABLE_PREFIX=mfp-dev-         # only used when STORE_BACKEND=dynamodb
AWS_DEFAULT_REGION=us-east-1

# =========================================================================
# Auth
# =========================================================================
# "local"   -- in-process login codes (default; zero AWS; used by tests).
# "cognito" -- AWS Cognito custom auth: Cognito emails the 6-digit code via the
#              pool's Lambda triggers (mfp-dev-auth-define/create/verify) and
#              verifies it; the backend then mints its own session token.
#              Requires the pool/client below + AWS credentials.
AUTH_BACKEND=local
COGNITO_USER_POOL_ID=            # e.g. us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=               # the pool's app client id
COGNITO_REGION=us-east-1

# Local auth only:
# "true"  -> the login code is returned in the API response (no email provider
#            needed; fine for local dev / early launch).
# "false" -> code is NOT returned; wire up email delivery to send it as a magic
#            link (see docs/deploy runbook).
AUTH_RETURN_CODE=true

# =========================================================================
# Billing (Stripe Checkout). Leave blank to run the app without payments --
# the paid tier can still be granted manually for testing (see DEPLOY.md).
# =========================================================================
STRIPE_SECRET_KEY=                # sk_live_... / sk_test_...
STRIPE_PRICE_ID=                  # price_... (the recurring paid-tier price)
STRIPE_WEBHOOK_SECRET=            # whsec_... (verifies webhook authenticity)

# Dev-only: lets a logged-in user unlock the paid tier WITHOUT Stripe, so you can
# demo/test premium features before billing is live. MUST be "false" in
# production -- otherwise anyone could self-upgrade for free.
ALLOW_DEV_UPGRADE=true

# =========================================================================
# Operator / admin console (frontend/public/admin.html + /api/admin/*)
# =========================================================================
# Shared secret that gates the admin API + dashboard (Bearer token). The console
# returns 503 until this is set. Use a strong random value in production --
# never commit the real value to this example file.
ADMIN_TOKEN=changeme-strong-random-value

# Optional: comma-separated allowlist of admin emails. When set, admin login
# requires BOTH the correct ADMIN_TOKEN and one of these emails. Leave blank
# to gate on the token alone.
ADMIN_EMAILS=hello@endevo.life,bluesproutagency@gmail.com

# =========================================================================
# Web / CORS
# =========================================================================
# Comma-separated origins allowed to call the API (your frontend URL[s]).
# NOTE: the Vite dev server is pinned to port 3200 (frontend/vite.config.js).
ALLOWED_ORIGINS=http://localhost:3200
# Where Stripe Checkout sends users back after payment.
APP_BASE_URL=http://localhost:3200

# =========================================================================
# Branding (optional -- defaults ship a neutral, expert-agnostic product)
# =========================================================================
PRODUCT_NAME=Final Playbook
# Leave EXPERT_NAME blank for a neutral, unnamed guide voice. Only set it if a
# specific expert is being surfaced WITH permission.
EXPERT_NAME=
