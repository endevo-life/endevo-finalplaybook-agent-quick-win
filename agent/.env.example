# Copy this file to .env and fill in real values. Never commit .env itself.

# =========================================================================
# LLM (paid tier only -- the free/rules tier needs none of this)
# =========================================================================
# Default backend: direct Anthropic API (recommended -- see docs/guardrails.md)
ANTHROPIC_API_KEY=

# "anthropic" (default, recommended) or "bedrock" (opt-in, experimentation only)
LLM_BACKEND=anthropic

# Only needed if LLM_BACKEND=bedrock
AWS_BEARER_TOKEN_BEDROCK=
BEDROCK_REGION=us-east-1
BEDROCK_MODEL_ID=meta.llama3-1-8b-instruct-v1:0

# =========================================================================
# Persistence (users, entitlements, sessions, usage metering)
# =========================================================================
# "memory" (default -- in-process, lost on restart; great for local dev/tests)
# or "dynamodb" (production).
STORE_BACKEND=memory
DDB_TABLE=final-playbook          # only used when STORE_BACKEND=dynamodb

# =========================================================================
# Auth
# =========================================================================
# "true"  -> the login code is returned in the API response (no email provider
#            needed; fine for local dev / early launch).
# "false" -> code is NOT returned; wire up email delivery to send it as a magic
#            link (see docs/deploy runbook).
AUTH_RETURN_CODE=true

# =========================================================================
# Billing (Stripe Checkout). Leave blank to run the app without payments --
# the paid tier can still be granted manually for testing (see DEPLOY.md).
# =========================================================================
STRIPE_SECRET_KEY=                # sk_live_... / sk_test_...
STRIPE_PRICE_ID=                  # price_... (the recurring paid-tier price)
STRIPE_WEBHOOK_SECRET=            # whsec_... (verifies webhook authenticity)

# Dev-only: lets a logged-in user unlock the paid tier WITHOUT Stripe, so you can
# demo/test premium features before billing is live. MUST be "false" in
# production -- otherwise anyone could self-upgrade for free.
ALLOW_DEV_UPGRADE=true

# =========================================================================
# Web / CORS
# =========================================================================
# Comma-separated origins allowed to call the API (your frontend URL[s]).
ALLOWED_ORIGINS=http://localhost:5173
# Where Stripe Checkout sends users back after payment.
APP_BASE_URL=http://localhost:5173

# =========================================================================
# Branding (optional -- defaults ship a neutral, expert-agnostic product)
# =========================================================================
PRODUCT_NAME=Final Playbook
# Leave EXPERT_NAME blank for a neutral, unnamed guide voice. Only set it if a
# specific expert is being surfaced WITH permission.
EXPERT_NAME=
